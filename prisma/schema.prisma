generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AccountType {
  ATTENDEE
  ORGANIZER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  SALES_CLOSED
  LIVE
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  RESERVED
  PAID
  ISSUED
  TRANSFER_PENDING
  RESALE_LISTED
  USED
  CANCELLED
  REFUNDED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum TransferStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum ResaleStatus {
  DRAFT
  LISTED
  SOLD
  CANCELLED
  EXPIRED
}

enum ScanOutcome {
  VALID
  ALREADY_USED
  INVALID
  BLOCKED
}

enum ScanMode {
  ONLINE
  OFFLINE_SYNC
}

enum StaffRole {
  OWNER
  ADMIN
  SCANNER
}

enum PaymentProvider {
  STRIPE
  PAYSTACK
  MANUAL
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum NotificationType {
  ORDER_PAID
  TRANSFER_CREATED
  TRANSFER_RECEIVED
  TRANSFER_REMINDER
  TRANSFER_ACCEPTED
  TRANSFER_CANCELLED
  TRANSFER_EXPIRED
  RESALE_LISTED
  RESALE_SOLD
  RESALE_CANCELLED
  EVENT_REMINDER
  POST_EVENT_PUBLISHED
}

enum NotificationStatus {
  UNREAD
  READ
}

enum PushPlatform {
  IOS
  ANDROID
}

enum PushDeviceStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum OwnershipChangeType {
  PURCHASE
  TRANSFER_OUT
  TRANSFER_IN
  RESALE_LISTED
  RESALE_PURCHASE
  ORGANIZER_REASSIGNMENT
  REFUND
  CANCELLATION
}

model User {
  id                       String                   @id @default(cuid())
  email                    String                   @unique
  passwordHash             String?                  @map("password_hash")
  accountType              AccountType              @default(ATTENDEE) @map("account_type")
  status                   UserStatus               @default(ACTIVE)
  lastLoginAt              DateTime?                @map("last_login_at")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")
  profile                  UserProfile?
  organizedEvents          Event[]                  @relation("event_organizer")
  orders                   Order[]
  ownedTickets             Ticket[]                 @relation("ticket_current_owner")
  transferRequestsCreated  TransferRequest[]        @relation("transfer_sender")
  transferRequestsReceived TransferRequest[]        @relation("transfer_recipient")
  resaleListings           ResaleListing[]          @relation("resale_seller")
  purchasedResales         ResaleListing[]          @relation("resale_buyer")
  ownershipHistoryFrom     TicketOwnershipHistory[] @relation("ownership_from_user")
  ownershipHistoryTo       TicketOwnershipHistory[] @relation("ownership_to_user")
  staffMemberships         StaffMembership[]
  scanSessionsStarted      ScanSession[]            @relation("scan_session_started_by")
  scanAttempts             ScanAttempt[]            @relation("scan_attempt_staff")
  notifications            UserNotification[]
  passwordResetTokens      PasswordResetToken[]
  pushDevices              PushDevice[]

  @@map("users")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, usedAt])
  @@map("password_reset_tokens")
}

model UserProfile {
  id          String    @id @default(cuid())
  userId      String    @unique @map("user_id")
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  phoneNumber String?   @map("phone_number")
  avatarUrl   String?   @map("avatar_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Event {
  id                   String            @id @default(cuid())
  organizerId          String            @map("organizer_id")
  title                String
  slug                 String            @unique
  description          String?
  venueName            String?           @map("venue_name")
  venueAddress         String?           @map("venue_address")
  timezone             String
  startsAt             DateTime          @map("starts_at")
  endsAt               DateTime?         @map("ends_at")
  status               EventStatus       @default(DRAFT)
  coverImageUrl        String?           @map("cover_image_url")
  salesStartAt         DateTime?         @map("sales_start_at")
  salesEndAt           DateTime?         @map("sales_end_at")
  allowResale          Boolean           @default(false) @map("allow_resale")
  minResalePrice       Decimal?          @db.Decimal(10, 2) @map("min_resale_price")
  maxResalePrice       Decimal?          @db.Decimal(10, 2) @map("max_resale_price")
  resaleRoyaltyPercent Decimal?          @db.Decimal(5, 2) @map("resale_royalty_percent")
  resaleStartsAt       DateTime?         @map("resale_starts_at")
  resaleEndsAt         DateTime?         @map("resale_ends_at")
  postEventMessage     String?           @map("post_event_message")
  postEventCtaLabel    String?           @map("post_event_cta_label")
  postEventCtaUrl      String?           @map("post_event_cta_url")
  postEventPublishedAt DateTime?         @map("post_event_published_at")
  postEventNotifiedAt  DateTime?         @map("post_event_notified_at")
  preEventReminderSentAt DateTime?       @map("pre_event_reminder_sent_at")
  offlineManifestSalt  String?           @map("offline_manifest_salt")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  organizer            User              @relation("event_organizer", fields: [organizerId], references: [id], onDelete: Restrict)
  ticketTypes          TicketType[]
  orders               Order[]
  tickets              Ticket[]
  resaleListings       ResaleListing[]
  staffMemberships     StaffMembership[]
  scanSessions         ScanSession[]
  scanAttempts         ScanAttempt[]
  payoutRecords        PayoutRecord[]
  webhookEvents        WebhookEvent[]

  @@index([organizerId, status])
  @@index([startsAt])
  @@map("events")
}

model TicketType {
  id                String    @id @default(cuid())
  eventId           String    @map("event_id")
  name              String
  description       String?
  price             Decimal   @db.Decimal(10, 2)
  currency          String    @default("EUR")
  quantity          Int
  maxPerOrder       Int?      @map("max_per_order")
  saleStartsAt      DateTime? @map("sale_starts_at")
  saleEndsAt        DateTime? @map("sale_ends_at")
  sortOrder         Int       @default(0) @map("sort_order")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems        OrderItem[]
  tickets           Ticket[]

  @@index([eventId, isActive])
  @@map("ticket_types")
}

model Order {
  id                     String          @id @default(cuid())
  userId                 String          @map("user_id")
  eventId                String          @map("event_id")
  status                 OrderStatus     @default(PENDING)
  currency               String          @default("EUR")
  subtotalAmount         Decimal         @db.Decimal(10, 2) @map("subtotal_amount")
  feeAmount              Decimal         @default(0) @db.Decimal(10, 2) @map("fee_amount")
  totalAmount            Decimal         @db.Decimal(10, 2) @map("total_amount")
  paymentProvider        PaymentProvider @default(STRIPE) @map("payment_provider")
  paymentReference       String?         @unique @map("payment_reference")
  checkoutSessionId      String?         @unique @map("checkout_session_id")
  idempotencyKey         String?         @unique @map("idempotency_key")
  paidAt                 DateTime?       @map("paid_at")
  cancelledAt            DateTime?       @map("cancelled_at")
  refundedAt             DateTime?       @map("refunded_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  user                   User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  event                  Event           @relation(fields: [eventId], references: [id], onDelete: Restrict)
  items                  OrderItem[]
  tickets                Ticket[]
  payoutRecords          PayoutRecord[]

  @@index([userId, createdAt])
  @@index([eventId, status])
  @@map("orders")
}

model OrderItem {
  id              String    @id @default(cuid())
  orderId         String    @map("order_id")
  ticketTypeId    String    @map("ticket_type_id")
  quantity        Int
  unitPrice       Decimal   @db.Decimal(10, 2) @map("unit_price")
  totalPrice      Decimal   @db.Decimal(10, 2) @map("total_price")
  createdAt       DateTime  @default(now()) @map("created_at")
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType      TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([ticketTypeId])
  @@map("order_items")
}

model Ticket {
  id                    String                   @id @default(cuid())
  eventId               String                   @map("event_id")
  ticketTypeId          String                   @map("ticket_type_id")
  orderId               String                   @map("order_id")
  currentOwnerId        String                   @map("current_owner_id")
  status                TicketStatus             @default(ISSUED)
  serialNumber          String                   @unique @map("serial_number")
  qrTokenId             String                   @unique @map("qr_token_id")
  ownershipRevision     Int                      @default(1) @map("ownership_revision")
  issuedAt              DateTime?                @map("issued_at")
  reservedUntil         DateTime?                @map("reserved_until")
  usedAt                DateTime?                @map("used_at")
  cancelledAt           DateTime?                @map("cancelled_at")
  refundedAt            DateTime?                @map("refunded_at")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")
  event                 Event                    @relation(fields: [eventId], references: [id], onDelete: Restrict)
  ticketType            TicketType               @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  order                 Order                    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  currentOwner          User                     @relation("ticket_current_owner", fields: [currentOwnerId], references: [id], onDelete: Restrict)
  ownershipHistory      TicketOwnershipHistory[]
  transferRequests      TransferRequest[]
  resaleListings        ResaleListing[]
  scanAttempts          ScanAttempt[]

  @@index([eventId, status])
  @@index([currentOwnerId, status])
  @@index([ticketTypeId])
  @@map("tickets")
}

model TicketOwnershipHistory {
  id             String              @id @default(cuid())
  ticketId       String              @map("ticket_id")
  fromUserId     String?             @map("from_user_id")
  toUserId       String?             @map("to_user_id")
  changeType     OwnershipChangeType @map("change_type")
  revision       Int
  metadata       Json?
  createdAt      DateTime            @default(now()) @map("created_at")
  ticket         Ticket              @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fromUser       User?               @relation("ownership_from_user", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser         User?               @relation("ownership_to_user", fields: [toUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, revision])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("ticket_ownership_history")
}

model TransferRequest {
  id                    String         @id @default(cuid())
  ticketId              String         @map("ticket_id")
  senderUserId          String         @map("sender_user_id")
  recipientUserId       String?        @map("recipient_user_id")
  recipientEmail        String?        @map("recipient_email")
  status                TransferStatus @default(PENDING)
  transferToken         String         @unique @map("transfer_token")
  message               String?
  expiresAt             DateTime       @map("expires_at")
  reminderSentAt        DateTime?      @map("reminder_sent_at")
  acceptedAt            DateTime?      @map("accepted_at")
  cancelledAt           DateTime?      @map("cancelled_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  ticket                Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderUser            User           @relation("transfer_sender", fields: [senderUserId], references: [id], onDelete: Restrict)
  recipientUser         User?          @relation("transfer_recipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, status])
  @@index([senderUserId, status])
  @@index([recipientUserId, status])
  @@map("transfer_requests")
}

model UserNotification {
  id         String             @id @default(cuid())
  userId     String             @map("user_id")
  type       NotificationType
  status     NotificationStatus @default(UNREAD)
  title      String
  body       String
  actionUrl  String?            @map("action_url")
  metadata   Json?
  readAt     DateTime?          @map("read_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([type, createdAt])
  @@map("user_notifications")
}

model PushDevice {
  id                String           @id @default(cuid())
  userId            String           @map("user_id")
  expoPushToken     String           @unique @map("expo_push_token")
  platform          PushPlatform
  status            PushDeviceStatus @default(ACTIVE)
  deviceName        String?          @map("device_name")
  appVersion        String?          @map("app_version")
  lastRegisteredAt  DateTime         @default(now()) @map("last_registered_at")
  lastDeliveredAt   DateTime?        @map("last_delivered_at")
  lastErrorAt       DateTime?        @map("last_error_at")
  lastErrorReason   String?          @map("last_error_reason")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("push_devices")
}

model ResaleListing {
  id                    String        @id @default(cuid())
  ticketId              String        @map("ticket_id")
  sellerUserId          String        @map("seller_user_id")
  buyerUserId           String?       @map("buyer_user_id")
  eventId               String        @map("event_id")
  askingPrice           Decimal       @db.Decimal(10, 2) @map("asking_price")
  currency              String        @default("EUR")
  organizerRoyaltyAmount Decimal?     @db.Decimal(10, 2) @map("organizer_royalty_amount")
  sellerNetAmount       Decimal?      @db.Decimal(10, 2) @map("seller_net_amount")
  status                ResaleStatus  @default(DRAFT)
  paymentProvider       PaymentProvider @default(STRIPE) @map("payment_provider")
  saleReference         String?       @unique @map("sale_reference")
  listedAt              DateTime?     @map("listed_at")
  soldAt                DateTime?     @map("sold_at")
  expiresAt             DateTime?     @map("expires_at")
  cancelledAt           DateTime?     @map("cancelled_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  ticket                Ticket        @relation(fields: [ticketId], references: [id], onDelete: Restrict)
  event                 Event         @relation(fields: [eventId], references: [id], onDelete: Restrict)
  sellerUser            User          @relation("resale_seller", fields: [sellerUserId], references: [id], onDelete: Restrict)
  buyerUser             User?         @relation("resale_buyer", fields: [buyerUserId], references: [id], onDelete: SetNull)
  payoutRecords         PayoutRecord[]

  @@index([ticketId, status])
  @@index([eventId, status])
  @@index([sellerUserId, status])
  @@map("resale_listings")
}

model StaffMembership {
  id               String    @id @default(cuid())
  eventId          String    @map("event_id")
  userId           String    @map("user_id")
  role             StaffRole
  invitedAt        DateTime? @map("invited_at")
  acceptedAt       DateTime? @map("accepted_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  event            Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanSessions     ScanSession[]
  scanAttempts     ScanAttempt[]

  @@unique([eventId, userId])
  @@index([userId, role])
  @@map("staff_memberships")
}

model ScanSession {
  id                   String           @id @default(cuid())
  eventId              String           @map("event_id")
  staffMembershipId    String?          @map("staff_membership_id")
  startedByUserId      String?          @map("started_by_user_id")
  deviceLabel          String?          @map("device_label")
  deviceFingerprint    String?          @map("device_fingerprint")
  mode                 ScanMode         @default(ONLINE)
  manifestVersion      Int?             @map("manifest_version")
  lastSyncedAt         DateTime?        @map("last_synced_at")
  startedAt            DateTime         @default(now()) @map("started_at")
  endedAt              DateTime?        @map("ended_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  event                Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  staffMembership      StaffMembership? @relation(fields: [staffMembershipId], references: [id], onDelete: SetNull)
  startedByUser        User?            @relation("scan_session_started_by", fields: [startedByUserId], references: [id], onDelete: SetNull)
  scanAttempts         ScanAttempt[]

  @@index([eventId, startedAt])
  @@index([deviceFingerprint])
  @@map("scan_sessions")
}

model ScanAttempt {
  id                   String           @id @default(cuid())
  eventId              String           @map("event_id")
  ticketId             String?          @map("ticket_id")
  scanSessionId        String?          @map("scan_session_id")
  staffMembershipId    String?          @map("staff_membership_id")
  scannedByUserId      String?          @map("scanned_by_user_id")
  scannedQrTokenId     String?          @map("scanned_qr_token_id")
  scannedRevision      Int?             @map("scanned_revision")
  outcome              ScanOutcome
  reasonCode           String?          @map("reason_code")
  scannedAt            DateTime         @default(now()) @map("scanned_at")
  deviceRecordedAt     DateTime?        @map("device_recorded_at")
  offlineQueuedAt      DateTime?        @map("offline_queued_at")
  syncedAt             DateTime?        @map("synced_at")
  metadata             Json?
  event                Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket               Ticket?          @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  scanSession          ScanSession?     @relation(fields: [scanSessionId], references: [id], onDelete: SetNull)
  staffMembership      StaffMembership? @relation(fields: [staffMembershipId], references: [id], onDelete: SetNull)
  scannedByUser        User?            @relation("scan_attempt_staff", fields: [scannedByUserId], references: [id], onDelete: SetNull)

  @@index([eventId, scannedAt])
  @@index([ticketId, scannedAt])
  @@index([scanSessionId, scannedAt])
  @@index([outcome, scannedAt])
  @@map("scan_attempts")
}

model PayoutRecord {
  id                  String          @id @default(cuid())
  eventId             String          @map("event_id")
  orderId             String?         @map("order_id")
  resaleListingId     String?         @map("resale_listing_id")
  paymentProvider     PaymentProvider @default(STRIPE) @map("payment_provider")
  payoutReference     String?         @unique @map("payout_reference")
  grossAmount         Decimal         @db.Decimal(10, 2) @map("gross_amount")
  feeAmount           Decimal         @default(0) @db.Decimal(10, 2) @map("fee_amount")
  netAmount           Decimal         @db.Decimal(10, 2) @map("net_amount")
  currency            String          @default("EUR")
  status              PayoutStatus    @default(PENDING)
  scheduledAt         DateTime?       @map("scheduled_at")
  paidAt              DateTime?       @map("paid_at")
  failedAt            DateTime?       @map("failed_at")
  failureReason       String?         @map("failure_reason")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  event               Event           @relation(fields: [eventId], references: [id], onDelete: Restrict)
  order               Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  resaleListing       ResaleListing?  @relation(fields: [resaleListingId], references: [id], onDelete: SetNull)

  @@index([eventId, status])
  @@index([orderId])
  @@index([resaleListingId])
  @@map("payout_records")
}

model WebhookEvent {
  id                  String          @id @default(cuid())
  eventId             String?         @map("event_id")
  provider            PaymentProvider @default(STRIPE)
  providerEventId     String          @unique @map("provider_event_id")
  eventType           String          @map("event_type")
  payload             Json
  processedAt         DateTime?       @map("processed_at")
  processingError     String?         @map("processing_error")
  createdAt           DateTime        @default(now()) @map("created_at")
  event               Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([provider, eventType])
  @@map("webhook_events")
}
